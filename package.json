{
  "name": "mx-kami",
  "license": "GPL-3.0",
  "private": false,
  "version": "4.6.7",
  "engines": {
    "node": ">=v14.21.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "next-pwa",
        "next"
      ]
    }
  },
  "bump": {
    "before": [
      "git pull --rebase",
      "ni"
    ],
    "changelog": true
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --cache --fix",
      "prettier --ignore-path ./.gitignore --write "
    ],
    "config.init.yaml": [
      "npm run gen-config && git add src/configs.default.ts"
    ]
  },
  "scripts": {
    "start": "npm run dev",
    "prebuild": "rimraf .next",
    "predev": "rimraf .next",
    "dev": "cross-env NODE_ENV=development next dev -p 2323",
    "analyze": "cross-env NODE_ENV=production ANALYZE=true BUNDLE_ANALYZE=browser next build",
    "build": "cross-env NODE_ENV=production next build",
    "build:ci": "cross-env NODE_ENV=production CI=true next build",
    "lint": "eslint \"**/*.{ts,tsx}\" --fix",
    "prod:pm2": "cross-env NODE_ENV=production pm2 restart ecosystem.config.js",
    "prod:pm2-alone": "cross-env NODE_ENV=production pm2 restart ecosystem.standalone.config.js",
    "prod:stop": "pm2 stop ecosystem.config.js",
    "prod:reload": "pm2 reload ecosystem.config.js",
    "gen-config": "node scripts/generate-default-configs.js",
    "gen-jsonschema": "npx ts-json-schema-generator --path 'src/types/config.ts' --type 'KamiConfig' > json-schema.json"
  },
  "browserslist": [
    "chrome >=94",
    "safari >=14",
    "last 2 Firefox versions"
  ],
  "dependencies": {
    "@floating-ui/react-dom": "2.1.8",
    "@formkit/auto-animate": "0.9.0",
    "@mx-space/api-client": "3.1.0",
    "@sentry/nextjs": "10.48.0",
    "axios": "1.15.0",
    "clsx": "2.1.1",
    "dayjs": "1.11.20",
    "devtools-detector": "2.0.25",
    "framer-motion": "10.18.0",
    "immer": "^10.2.0",
    "js-cookie": "3.0.5",
    "lodash-es": "4.18.1",
    "markdown-escape": "2.0.0",
    "markdown-to-jsx": "npm:@innei/markdown-to-jsx@7.4.5-fork.4",
    "medium-zoom": "1.1.0",
    "mermaid": "11.14.0",
    "next": "15.5.15",
    "next-intl": "^4.9.1",
    "next-seo": "6.8.0",
    "next-suspense": "0.2.3",
    "randomcolor": "0.6.2",
    "react": "18.3.1",
    "react-countup": "6.5.3",
    "react-dom": "18.3.1",
    "react-error-boundary": "4.1.2",
    "react-intersection-observer": "9.16.0",
    "react-masonry-css": "1.0.16",
    "react-message-popup": "1.1.3",
    "react-shortcut-guide": "1.0.0",
    "react-smooth-number-counter": "npm:@reactify-components/smooth-number-counter",
    "react-toastify": "9.1.3",
    "react-use": "17.6.0",
    "remove-markdown": "0.6.3",
    "socket.io-client": "4.8.3",
    "swr": "2.4.1",
    "validator": "13.15.35",
    "xss": "1.0.15",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "15.5.15",
    "@sentry/webpack-plugin": "5.2.0",
    "@trivago/prettier-plugin-sort-imports": "4.3.0",
    "@types/inflection": "1.13.2",
    "@types/js-cookie": "3.0.6",
    "@types/lodash-es": "4.17.12",
    "@types/markdown-escape": "1.1.3",
    "@types/node": "20.19.39",
    "@types/randomcolor": "0.5.9",
    "@types/react": "18.3.28",
    "@types/react-color": "3.0.13",
    "@types/react-dom": "18.3.7",
    "@types/remove-markdown": "0.3.4",
    "@types/ua-parser-js": "0.7.39",
    "@types/validator": "13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "cross-env": "7.0.3",
    "dotenv": "16.6.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "8.0.3",
    "js-yaml": "4.1.1",
    "lint-staged": "15.5.2",
    "markdown-to-jsx": "npm:@innei/markdown-to-jsx@7.4.5-fork.4",
    "next-compose-plugins": "2.2.1",
    "npm-check-updates": "^20.0.1",
    "postcss": "8.5.9",
    "postcss-import": "15.1.0",
    "postcss-nested": "6.2.0",
    "postcss-preset-env": "9.6.0",
    "prettier": "3.8.2",
    "pug": "^3.0.4",
    "rimraf": "^6.1.3",
    "tilg": "0.1.1",
    "typescript": "5.9.3",
    "webpack": "^5.106.1",
    "windicss": "3.5.6",
    "windicss-webpack-plugin": "1.8.0",
    "zx": "8.8.5"
  },
  "resolutions": {
    "react-use": "17.6.0",
    "@types/react": "17.0.68"
  },
  "nextBundleAnalysis": {
    "budget": 358400,
    "budgetPercentIncreaseRed": 20,
    "showDetails": true
  },
  "packageManager": "pnpm@10.33.0"
}